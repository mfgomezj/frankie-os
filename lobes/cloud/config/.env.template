# === LLM Provider ===
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-v1-REEMPLAZAR

# === Telegram Gateway ===
TELEGRAM_BOT_TOKEN=REEMPLAZAR
TELEGRAM_ALLOWED_USERS=REEMPLAZAR          # User ID del dueño (separados por coma si son varios)
